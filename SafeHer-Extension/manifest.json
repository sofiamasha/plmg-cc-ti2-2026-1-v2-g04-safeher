{
  "manifest_version": 3,
  "name": "SafeHer Extension",
  "version": "1.0.0",
  "description": "Veja o índice de segurança e avaliações de empresas diretamente no LinkedIn, Glassdoor e plataformas de vagas.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.svg",
      "48": "icon.svg",
      "128": "icon.svg"
    }
  },
  "icons": {
    "16": "icon.svg",
    "48": "icon.svg",
    "128": "icon.svg"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
