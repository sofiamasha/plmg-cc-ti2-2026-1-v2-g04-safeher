# =============================================
#   SafeHer API — Variáveis de Ambiente
# =============================================
# Copie este arquivo para .env e preencha os valores

# Servidor
PORT=3000
NODE_ENV=development

# Banco de Dados PostgreSQL
# Mesmo banco usado pelo backend Java
DB_HOST=localhost
DB_PORT=5432
DB_NAME=safeher
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=troque_por_uma_chave_secreta_forte_aqui
JWT_EXPIRES_IN=7d

# CORS — Origens permitidas (extensão e frontend)
# Separe múltiplas origens com vírgula
CORS_ORIGINS=*
